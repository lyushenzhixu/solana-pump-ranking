# 从 Supabase 控制台获取：项目设置 -> API
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://你的项目ID.supabase.co
SUPABASE_ANON_KEY=你的anon公钥

# AVE Cloud API（可选，已被自研数据源替代，保留供 ave-cloud skill 使用）
# 免费注册：https://cloud.ave.ai/register
# AVE_API_KEY=你的AVE_API_KEY
# API_PLAN=free

# 自研数据源说明（无需额外配置）：
# 榜单拉取使用 DexScreener + GeckoTerminal + Jupiter + GoPlus
# 所有 API 均免费、无需 Key，详见 src/data-sources/

# 定时自动更新间隔（分钟），默认 5 分钟，最小 1 分钟
# AUTO_UPDATE_INTERVAL_MIN=5

# ── SEO ──
# 站点 URL，用于生成 canonical、sitemap、OG 标签等，默认 https://zhizhilabs.com
# SITE_URL=https://zhizhilabs.com

# ── Google Analytics ──
# 前端追踪：设置后自动在页面注入 gtag.js，不设置则不启用追踪
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# MCP 查询（在 Cursor 中通过自然语言查询 GA 数据）
# 1. 在 Google Cloud Console 创建 Service Account 并下载 JSON 密钥
# 2. 启用 Google Analytics Data API
# 3. 将 Service Account 邮箱添加到 GA4 媒体资源（Viewer 权限）
# 4. 填入 GA4 媒体资源 ID（纯数字，如 123456789）
GA_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GA4_PROPERTY_ID=123456789

# 6551 OpenNews / OpenTwitter API Token（加密新闻叙事 + 热门推特）
# 获取地址：https://6551.io/mcp
# 两个 API 使用同一个 Token，配置任意一个即可（代码会自动 fallback）
# 也可以统一使用 TOKEN_6551
# OPENNEWS_TOKEN=你的6551_API_Token
# TWITTER_TOKEN=你的6551_API_Token
# TOKEN_6551=你的6551_API_Token

# ── 叙事/推文缓存配置 ──
# Supabase 持久化缓存 TTL（小时），减少 API 调用次数
# 需要先执行 config/sql/token-narrative-cache.sql 创建表
# NARRATIVE_CACHE_TTL_HOURS=4
# TWEET_CACHE_TTL_HOURS=2

# 是否在榜单更新后自动预取推文（会消耗 Twitter API 配额）
# 设为 true 开启，默认 false（仅预取叙事，叙事走 OpenNews 成本较低）
# ENABLE_TWEET_PREFETCH=false
